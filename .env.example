# Copy to .env and fill in values. Never commit .env.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/merchant_sweep

# ── Price provider (§5.1) ─────────────────────────────────────────────────────
PRICE_PROVIDER=coingecko_free
COINGECKO_API_KEY=          # optional; omit for free tier
PRICE_POLL_INTERVAL_SECONDS=60

# ── Coinbase venue (§5.7) ─────────────────────────────────────────────────────
# Default is sandbox. Set to "production" only after explicit testing sign-off.
COINBASE_ENV=sandbox
COINBASE_RATE_LIMIT_RPS=10
SWEEP_MAX_SLIPPAGE_PCT=2.0
